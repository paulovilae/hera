# Hera - Multimodal LLM Engine
# Environment Configuration

HERA_ENV=development

# Native AI Model Toggles
HERA_ENABLE_FLUX=false
HERA_ENABLE_PARLER=false
HERA_ENABLE_WHISPER=false
HERA_ENABLE_LLM=true

# Cloud Fallback
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
